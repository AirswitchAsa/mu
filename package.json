{
  "name": "mu",
  "version": "0.0.0",
  "private": true,
  "description": "A generative-UI playground for financial research.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "typecheck": "tsc --build",
    "start": "node packages/server/dist/main.js",
    "test": "vitest run --root .",
    "test:watch": "vitest --root .",
    "dev:web": "pnpm --filter @mu/web dev",
    "build:web": "pnpm --filter @mu/web build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
