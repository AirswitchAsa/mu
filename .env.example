# µ configuration — copy to `.env` (gitignored) and fill in what you need.
# Everything here is OPTIONAL: µ runs out of the box with no keys (Yahoo/CNBC RSS
# for prices + news). API keys only unlock the keyed data sources.

# --- the agent (drives the chat/agent loop) ----------------------------------
# Any provider/model your opencode install is authed for, e.g. deepseek/deepseek-chat.
# Leave unset or empty to run API-only (no agent; /message returns NO_DRIVER).
MU_MODEL=

# --- data source API keys (optional; each gates one resource) -----------------
FINNHUB_API_KEY=   # company news + earnings (EPS/revenue) + key statistics
FRED_API_KEY=      # US macro releases (GDP, CPI, unemployment, yields, ...)

# --- server (all optional; sensible defaults shown) --------------------------
# PORT=4000
# MU_DATA_ROOT=./.mu-data        # where the parquet store lives
# MU_RESOURCES_DIR=./resources   # first-party resource packages
# MU_TURN_TIMEOUT_MS=180000      # per-agent-turn deadline
# MU_TOOL_TIMEOUT_MS=60000       # per-tool-call deadline

# --- web client (optional) ---------------------------------------------------
# VITE_MU_API=http://127.0.0.1:4000  # override the API base the browser calls
