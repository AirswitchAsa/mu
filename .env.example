# µ configuration — copy to `.env` (gitignored) and fill in what you need.
# Everything here is OPTIONAL: µ runs out of the box with no keys (Yahoo/CNBC RSS
# for prices + news). API keys only unlock the keyed data sources.

# --- the agent (drives the chat/agent loop) ----------------------------------
# Two values turn the agent on: a "provider/model" and that provider's API key. The key
# var follows the convention <PROVIDER>_API_KEY (deepseek → DEEPSEEK_API_KEY, openai →
# OPENAI_API_KEY, …). Leave MU_MODEL unset to run API-only (no agent; /message → NO_DRIVER).
# If MU_MODEL is set but the key is missing, µ FAILS FAST at startup with a clear message.
# (NB: µ relocates opencode's storage under MU_DATA_ROOT so sessions survive a restart —
# the relocated home does NOT see `opencode auth login`'s auth.json, so the key must come
# from here, not from a prior login.)
MU_MODEL=deepseek/deepseek-v4-pro
DEEPSEEK_API_KEY=

# --- data source API keys (optional; each gates one resource) -----------------
FINNHUB_API_KEY=   # company news + earnings (EPS/revenue) + key statistics
FRED_API_KEY=      # US macro releases (GDP, CPI, unemployment, yields, ...)

# --- backend / API server (all optional; sensible defaults shown) ------------
# PORT=4000                      # the µ HTTP/SSE API port (NOT the web client)
# MU_DATA_ROOT=./.mu-data        # where the parquet store lives
# MU_RESOURCES_DIR=./resources   # first-party resource packages
# MU_TURN_TIMEOUT_MS=180000      # per-agent-turn deadline
# MU_TOOL_TIMEOUT_MS=60000       # per-tool-call deadline

# --- web client (optional; Vite dev server runs on :5173) --------------------
# VITE_MU_API=http://127.0.0.1:4000  # the API base the browser calls (the PORT above)
