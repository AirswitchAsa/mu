{
  "name": "@mu/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "µ server: HTTP/SSE composition root. Boots the runtime, loads resources, drives opencode.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "bin": {
