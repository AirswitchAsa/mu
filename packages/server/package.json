    "start": "node dist/main.js"
  },
  "dependencies": {
    "@mu/protocol": "workspace:*",
    "@mu/broker": "workspace:*",
    "@mu/resource-sdk": "workspace:*",
    "@mu/runtime": "workspace:*",
    "@mu/opencode-plugin": "workspace:*"
  }
