{
  // µ end-to-end. Pick "µ end-to-end" in the Run and Debug panel (▷) to start the
  // backend (:4000) and the web dev server (:5173) together, then open
  // http://localhost:5173 and talk to the agent.
  //
  // Config comes from `.env` (gitignored; copy from .env.example). Two values turn the
  // agent on: MU_MODEL (provider/model) + that provider's <PROVIDER>_API_KEY. Leave
  // MU_MODEL unset for API-only (no agent; /message returns NO_DRIVER). Do NOT set
  // MU_MODEL here — `env` entries override `.env` (Node won't overwrite an already-set
  // var), which would pin a stale model.
  //
  // node-terminal launches run in an integrated terminal and auto-attach the JS
  // debugger, so breakpoints in the server's TS (dist sourcemaps) work.
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "µ server (:4000)",
      "command": "pnpm build && pnpm start",
      "cwd": "${workspaceFolder}"
      // No `env` — `.env` is the single source (MU_MODEL, DEEPSEEK_API_KEY, PORT…).
      // PORT defaults to 4000 in main.ts; set it in `.env` to change it.
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "µ web (vite :5173)",
      "command": "pnpm dev:web",
      "cwd": "${workspaceFolder}"
      // The dev server defaults to API http://127.0.0.1:4000; override with
      // "env": { "VITE_MU_API": "http://127.0.0.1:4000" } if you change PORT.
    },
    {
      "type": "msedge",
      "request": "launch",
      "name": "µ open in browser",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/packages/web"
      // Swap "type" to "chrome" if you prefer Chrome. Not in the compound below so a
      // missing browser never blocks the servers; launch it once they're up.
    }
  ],
  "compounds": [
    {
      "name": "µ end-to-end",
      "configurations": ["µ server (:4000)", "µ web (vite :5173)"],
      "stopAll": true
    }
  ]
}
